  banks:     ['البنك الأهلي السعودي','بنك الراجحي','بنك الرياض','البنك السعودي الفرنسي','بنك البلاد','بنك الجزيرة','البنك السعودي للاستثمار','بنك الإمارات دبي الوطني','بنك الإنماء','بنك الخليج الدولي (ميم)','أخرى'],
  capital:   ['مدخرات شخصية','دخل الراتب','أرباح استثمارية','هبة / ميراث','تمويل بنكي','شريك / مستثمر'],
  types:     ['صك','صندوق','سهم','سند','مرابحة','وديعة','عقار','مشروع','عقد آجل','أخرى'],
};

var DATA = { platforms:[], banks:[], capital:[], types:[] };

// ══ Auth ══
function signIn() {
  _auth.signInWithPopup(_provider).catch(function(e){ showToast('❌ ' + e.message); });
}

_auth.onAuthStateChanged(function(user) {
  if (user) {
    _uid = user.uid;
    document.getElementById('login-gate').style.display = 'none';
    document.getElementById('user-name').textContent  = user.displayName || 'مستخدم';
    document.getElementById('user-email').textContent = user.email || '';
    document.getElementById('user-avatar').textContent = (user.displayName || 'U')[0];
    loadAllSettings();
  } else {
    document.getElementById('login-gate').style.display = 'flex';
  }
});

// ══ Firestore helpers ══
function settingsRef() {
  return _db.collection('users').doc(_uid).collection('portfolio').doc('settings');
}

function loadAllSettings() {
  settingsRef().get().then(function(snap) {
    var s = snap.exists ? snap.data() : {};
    DATA.platforms = s.platforms || DEFAULTS.platforms.slice();
    DATA.banks     = s.banks     || DEFAULTS.banks.slice();
    DATA.capital   = s.capital   || DEFAULTS.capital.slice();
    DATA.types     = s.types     || DEFAULTS.types.slice();
    renderAllLists();
    // display settings
    if (s.theme)       setTheme(s.theme, true);
    if (s.toggles)     loadToggles(s.toggles);
  }).catch(function(e){ showToast('❌ ' + e.message); });
}

// ══ List rendering ══
function renderList(key) {
  var el = document.getElementById('list-' + key);
  if (!el) return;
  if (!DATA[key].length) {
    el.innerHTML = '<div class="empty-list">لا توجد عناصر — أضف من أدناه</div>';
    return;
  }
  el.innerHTML = DATA[key].map(function(item, i) {
    return '<div class="list-item">'
      + '<span class="item-drag" title="سحب لإعادة الترتيب">⠿</span>'
      + '<input class="list-item-text" value="' + escHtml(item) + '" onchange="DATA[\'' + key + '\'][' + i + ']=this.value" />'
      + '<button class="item-delete" onclick="deleteItem(\'' + key + '\',' + i + ')" title="حذف">✕</button>'
      + '</div>';
  }).join('');
}

function renderAllLists() {
  ['platforms','banks','capital','types'].forEach(renderList);
}

function addItem(key) {
  var inp = document.getElementById('inp-' + key);
  var val = inp.value.trim();
  if (!val) { inp.focus(); return; }
  if (DATA[key].includes(val)) { showToast('⚠️ موجود مسبقاً'); return; }
  DATA[key].push(val);
  inp.value = '';
  renderList(key);
}

function deleteItem(key, idx) {
  DATA[key].splice(idx, 1);
  renderList(key);
}

function saveList(key) {
  var obj = {};
  obj[key] = DATA[key];
  settingsRef().set(obj, { merge: true })
    .then(function(){ showToast('✅ تم حفظ ' + labelOf(key)); })
    .catch(function(e){ showToast('❌ ' + e.message); });
}

function labelOf(key) {
  return { platforms:'المنصات', banks:'البنوك', capital:'مصادر رأس المال', types:'أنواع الاستثمار' }[key] || key;
}

// ══ Theme ══
var _currentTheme = 'dark';
function setTheme(name, silent) {
  _currentTheme = name;
  document.querySelectorAll('.theme-card').forEach(function(c){ c.classList.remove('selected'); });
  var el = document.getElementById('theme-' + name);
  if (el) el.classList.add('selected');
  if (!silent) showToast('🎨 سيُطبَّق الثيم عند فتح التطبيق');
}

// ══ Toggles ══
var _toggles = { prices: true, alerts: true, 'arabic-nums': false };
function toggleOpt(key) {
  _toggles[key] = !_toggles[key];
  var el = document.getElementById('tog-' + key);
  if (el) el.classList.toggle('on', _toggles[key]);
}
function loadToggles(t) {
  Object.keys(t).forEach(function(k) {
    _toggles[k] = t[k];
    var el = document.getElementById('tog-' + k);
    if (el) el.classList.toggle('on', t[k]);
  });
}

function saveDisplaySettings() {
  settingsRef().set({ theme: _currentTheme, toggles: _toggles }, { merge: true })
    .then(function(){ showToast('✅ تم حفظ إعدادات العرض'); })
    .catch(function(e){ showToast('❌ ' + e.message); });
}

// ══ Navigation ══
var SECTIONS = {
  platforms: { title: '🏢 المنصات والوسطاء',    sub: 'إدارة قائمة المنصات المتاحة عند إضافة الفرص الاستثمارية' },
  banks:     { title: '🏦 البنوك للقروض',        sub: 'إدارة قائمة البنوك والجهات الممولة للقروض' },
  capital:   { title: '💰 مصادر رأس المال',      sub: 'مصادر تمويل الاستثمارات (راتب، مدخرات، أرباح...)' },
  types:     { title: '📋 أنواع الاستثمار',      sub: 'الأنواع المتاحة عند إضافة فرصة جديدة' },
  display:   { title: '🎨 العرض والثيم',         sub: 'تخصيص مظهر التطبيق وخيارات العرض' },
};

function showSection(key) {
  document.querySelectorAll('.section').forEach(function(s){ s.classList.remove('active'); });
  document.querySelectorAll('.nav-item').forEach(function(n){ n.classList.remove('active'); });
  var sec = document.getElementById('sec-' + key);
  if (sec) sec.classList.add('active');
  event.currentTarget.classList.add('active');
  var info = SECTIONS[key] || {};
  document.getElementById('section-title').textContent = info.title || '';
  document.getElementById('section-sub').textContent   = info.sub   || '';
}

// ══ Toast ══
function showToast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.style.borderColor = msg.startsWith('✅') ? 'var(--green)' : msg.startsWith('⚠️') ? 'var(--orange)' : 'var(--red)';
  t.style.color = msg.startsWith('✅') ? 'var(--green)' : msg.startsWith('⚠️') ? 'var(--orange)' : 'var(--red)';
  t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 2500);
}

function escHtml(s) {
  return (s||'').replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
</script>
</body>
</html>
