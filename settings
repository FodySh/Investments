      تسجيل الدخول بـ Google
    </button>
  </div>
</div>

<!-- App -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <div class="logo-mark">PORTFOLIO</div>
    <div class="logo-title">⚙️ الإعدادات</div>
    <div class="logo-sub">إدارة قوائم وتفضيلات التطبيق</div>
  </div>

  <div class="nav-section">
    <div class="nav-label">القوائم</div>
    <div class="nav-item active" onclick="showSection('platforms')"><span class="nav-icon">🏢</span> المنصات والوسطاء</div>
    <div class="nav-item" onclick="showSection('banks')"><span class="nav-icon">🏦</span> البنوك للقروض</div>
    <div class="nav-item" onclick="showSection('capital')"><span class="nav-icon">💰</span> مصادر رأس المال</div>
    <div class="nav-item" onclick="showSection('types')"><span class="nav-icon">📋</span> أنواع الاستثمار</div>
  </div>
  <div class="nav-section">
    <div class="nav-label">التفضيلات</div>
    <div class="nav-item" onclick="showSection('display')"><span class="nav-icon">🎨</span> العرض والثيم</div>
  </div>

  <div class="sidebar-footer">
    <div class="user-pill">
      <div class="user-avatar" id="user-avatar">—</div>
      <div>
        <div class="user-name" id="user-name">—</div>
        <div class="user-email" id="user-email">—</div>
      </div>
    </div>
    <a href="investment-app.html" class="back-btn">← العودة للتطبيق</a>
  </div>
</aside>

<main class="main">
  <div class="page-header">
    <div class="page-title" id="section-title">🏢 المنصات والوسطاء</div>
    <div class="page-sub" id="section-sub">إدارة قائمة المنصات المتاحة عند إضافة الفرص الاستثمارية</div>
  </div>

  <!-- ══ PLATFORMS ══ -->
  <div class="section active" id="sec-platforms">
    <div class="card">
      <div class="card-title">🏢 قائمة المنصات والوسطاء</div>
      <div class="list-items" id="list-platforms"></div>
      <div class="add-item-row">
        <input class="add-input" id="inp-platform" placeholder="اسم المنصة الجديدة..." onkeydown="if(event.key==='Enter') addItem('platforms')" />
        <button class="add-btn" onclick="addItem('platforms')">+ إضافة</button>
      </div>
    </div>
    <button class="save-section-btn" onclick="saveList('platforms')">💾 حفظ التغييرات</button>
  </div>

  <!-- ══ BANKS ══ -->
  <div class="section" id="sec-banks">
    <div class="card">
      <div class="card-title">🏦 قائمة البنوك للقروض</div>
      <div class="list-items" id="list-banks"></div>
      <div class="add-item-row">
        <input class="add-input" id="inp-bank" placeholder="اسم البنك الجديد..." onkeydown="if(event.key==='Enter') addItem('banks')" />
        <button class="add-btn" onclick="addItem('banks')">+ إضافة</button>
      </div>
    </div>
    <button class="save-section-btn" onclick="saveList('banks')">💾 حفظ التغييرات</button>
  </div>

  <!-- ══ CAPITAL ══ -->
  <div class="section" id="sec-capital">
    <div class="card">
      <div class="card-title">💰 مصادر رأس المال</div>
      <div class="list-items" id="list-capital"></div>
      <div class="add-item-row">
        <input class="add-input" id="inp-capital" placeholder="مثال: مدخرات، دخل الراتب..." onkeydown="if(event.key==='Enter') addItem('capital')" />
        <button class="add-btn" onclick="addItem('capital')">+ إضافة</button>
      </div>
    </div>
    <button class="save-section-btn" onclick="saveList('capital')">💾 حفظ التغييرات</button>
  </div>

  <!-- ══ TYPES ══ -->
  <div class="section" id="sec-types">
    <div class="card">
      <div class="card-title">📋 أنواع الاستثمار</div>
      <div class="list-items" id="list-types"></div>
      <div class="add-item-row">
        <input class="add-input" id="inp-type" placeholder="مثال: صك، صندوق، عقار..." onkeydown="if(event.key==='Enter') addItem('types')" />
        <button class="add-btn" onclick="addItem('types')">+ إضافة</button>
      </div>
    </div>
    <button class="save-section-btn" onclick="saveList('types')">💾 حفظ التغييرات</button>
  </div>

  <!-- ══ DISPLAY ══ -->
  <div class="section" id="sec-display">
    <div class="card">
      <div class="card-title">🎨 الثيم والألوان</div>
      <div class="theme-grid">
        <div class="theme-card selected" onclick="setTheme('dark')" id="theme-dark">
          <div class="theme-swatch" style="background:linear-gradient(135deg,#050e0a,#0f2218)"></div>
          <div class="theme-name">🌙 داكن (الافتراضي)</div>
        </div>
        <div class="theme-card" onclick="setTheme('darker')" id="theme-darker">
          <div class="theme-swatch" style="background:linear-gradient(135deg,#000,#111)"></div>
          <div class="theme-name">⬛ أسود خالص</div>
        </div>
        <div class="theme-card" onclick="setTheme('navy')" id="theme-navy">
          <div class="theme-swatch" style="background:linear-gradient(135deg,#050a1a,#0a1028)"></div>
          <div class="theme-name">🌊 نيلي</div>
        </div>
        <div class="theme-card" onclick="setTheme('forest')" id="theme-forest">
          <div class="theme-swatch" style="background:linear-gradient(135deg,#021a08,#052810)"></div>
          <div class="theme-name">🌿 غابي</div>
        </div>
      </div>
    </div>

    <div class="card">
      <div class="card-title">⚙️ خيارات العرض</div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label">إظهار الأسعار المحدّثة تلقائياً</div>
          <div class="toggle-sub">تحديث أسعار الأسهم كل 5 دقائق</div>
        </div>
        <div class="toggle on" id="tog-prices" onclick="toggleOpt('prices')">
          <div class="toggle-knob"></div>
        </div>
      </div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label">إظهار تحذيرات الاستحقاق</div>
          <div class="toggle-sub">تنبيهات للاستثمارات القريبة من الانتهاء</div>
        </div>
        <div class="toggle on" id="tog-alerts" onclick="toggleOpt('alerts')">
          <div class="toggle-knob"></div>
        </div>
      </div>
      <div class="toggle-row">
        <div>
          <div class="toggle-label">الأرقام بالتنسيق العربي</div>
          <div class="toggle-sub">مثال: ١٢٣,٤٥٦ بدل 123,456</div>
        </div>
        <div class="toggle" id="tog-arabic-nums" onclick="toggleOpt('arabic-nums')">
          <div class="toggle-knob"></div>
        </div>
      </div>
    </div>
    <button class="save-section-btn" onclick="saveDisplaySettings()">💾 حفظ الإعدادات</button>
  </div>
</main>

